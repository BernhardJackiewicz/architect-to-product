{
  "name": "architect-to-product",
  "version": "1.0.5",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "architect-to-product": "dist/index.js",
    "a2p": "dist/cli.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE",
    "VALIDATION.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
